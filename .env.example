# Runtime storage root. Override this if your team is not using /data.
export CLINICAL_SPEECH_RUNTIME_ROOT=/data/project_runtime

# Required only for gated Meta Llama configs such as configs/proposed_system.yaml.
# You can also authenticate with `huggingface-cli login` instead of exporting HF_TOKEN.
export HF_TOKEN=

# Required only for the hosted Together benchmark path.
export TOGETHER_API_KEY=
export TOGETHER_BASE_URL=https://api.together.xyz/v1

# Optional if you use Weights & Biases outside the managed runtime directories.
export WANDB_API_KEY=
